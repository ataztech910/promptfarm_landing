    "dev:example": "cd example && npx vite",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@promptfarm/editor-core": "file:../editor-core",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
