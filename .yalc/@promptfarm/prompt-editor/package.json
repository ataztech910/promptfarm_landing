{
  "name": "@promptfarm/prompt-editor",
  "version": "0.4.7",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node_modules/.bin/tailwindcss -i ./src/styles.css -o ./dist/styles.css",
